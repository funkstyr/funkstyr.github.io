---
import { getEntry } from "astro:content";

import { getAllPosts, getSeriesPosts } from "../utils/post";

const SERIES_ID = "claude-code";

const allPosts = await getAllPosts();
const seriesPosts = getSeriesPosts(allPosts, SERIES_ID);
const series = await getEntry("series", SERIES_ID);

const firstPost = seriesPosts[0];
---

<div class='flex flex-col gap-4'>
  {series && firstPost && (
    <div class='rounded-2xl border border-border bg-primary-foreground px-5 py-4'>
      <div>
        <a
          href={`/blog/${firstPost.id}/`}
          class='text-lg font-bold transition-all hover:text-muted-foreground'
          data-astro-prefetch
        >
          {series.data.heading}
        </a>
        <p class='text-sm text-muted-foreground mt-1'>
          {series.data.description}
        </p>
        <a
          href={`/blog/${firstPost.id}/`}
          class='inline-block mt-3 text-sm font-medium transition-all hover:text-muted-foreground'
          data-astro-prefetch
        >
          Start with Part 1 →
        </a>
      </div>
    </div>
  )}
</div>
