---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";

import { Font, getImage } from "astro:assets";
import { siteConfig } from "../site.config";
import { resumeData } from "../data/resume";
import type { SiteMeta } from "../types";
import { ogImagePath, ogSlugForPathname } from "../utils/og";
import JsonLd from "./JsonLd.astro";
import avatarSrc from "../assets/avatar.jpg";

type Props = SiteMeta;

const {
  articleDate,
  articleTags,
  description,
  noindex,
  ogImage,
  ogImageAlt,
  title,
} = Astro.props;

const { contact } = resumeData;
const titleSeparator = "•";
const isHomepage = Astro.url.pathname === "/" || Astro.url.pathname === "";
const siteTitle = isHomepage
	? `${contact.name} - Senior Software Engineer ${titleSeparator} ${siteConfig.title}`
	: `${title} ${titleSeparator} ${siteConfig.title}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Pages pass an explicit ogImage (blog posts use their generated per-post
// card); otherwise fall back to the build-time card for this pathname.
const socialImageURL = new URL(
  ogImage ?? ogImagePath(ogSlugForPathname(Astro.url.pathname)),
  Astro.url
).href;

// Preload the AVIF avatar on pages that render it (home + resume) so it
// races the parser to first paint instead of waiting for body discovery.
const showsAvatar =
  Astro.url.pathname === "/" ||
  Astro.url.pathname === "" ||
  Astro.url.pathname.startsWith("/resume");
const preloadAvatar = showsAvatar
  ? await getImage({
      src: avatarSrc,
      width: 224,
      height: 224,
      format: "avif",
      quality: 33,
    })
  : null;
---

<meta charset='utf-8' />
<meta
  content='width=device-width, initial-scale=1.0, shrink-to-fit=no'
  name='viewport'
/>
<title>{siteTitle}</title>

{/* Privacy / security defaults. GitHub Pages can't set response headers,
    so we do what's possible via <meta>. */}
<meta name='referrer' content='strict-origin-when-cross-origin' />
<meta
  http-equiv='Content-Security-Policy'
  content="default-src 'self'; script-src 'self' 'unsafe-inline' https://giscus.app https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://giscus.app; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://cloudflareinsights.com; frame-src https://giscus.app; media-src 'self'; manifest-src 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
/>

<link
  rel='apple-touch-icon'
  sizes='180x180'
  href='/favicon/apple-touch-icon.png'
/>
<link
  rel='icon'
  type='image/png'
  sizes='32x32'
  href='/favicon/favicon-32x32.png'
/>
<link
  rel='icon'
  type='image/png'
  sizes='16x16'
  href='/favicon/favicon-16x16.png'
/>
<link rel='manifest' href='/favicon/site.webmanifest' />

{/* LCP image preload (only on pages that render it) */}
{preloadAvatar && (
  <link
    rel='preload'
    as='image'
    type='image/avif'
    href={preloadAvatar.src}
    fetchpriority='high'
  />
)}

{/* Font preloads */}
<Font cssVariable="--font-sans" preload />

{/* Canonical URL */}
<link rel='canonical' href={canonicalURL} />

{/* Hreflang */}
<link rel='alternate' hreflang={siteConfig.lang} href={canonicalURL} />
<link rel='alternate' hreflang='x-default' href={canonicalURL} />

{/* Primary Meta Tags */}
<meta content={siteTitle} name='title' />
<meta content={description} name='description' />
<meta content={siteConfig.author} name='author' />
{noindex && <meta name='robots' content='noindex, nofollow' />}

{/* Theme Colour */}
<meta name='color-scheme' content='light dark' />
<meta content='#0f172a' name='theme-color' media='(prefers-color-scheme: dark)' />
<meta content='#f1f5f9' name='theme-color' media='(prefers-color-scheme: light)' />

{/* Open Graph / Facebook */}
<meta content={articleDate ? "article" : "website"} property='og:type' />
<meta content={title} property='og:title' />
<meta content={description} property='og:description' />
<meta content={canonicalURL} property='og:url' />
<meta content={siteConfig.title} property='og:site_name' />
<meta content={siteConfig.ogLocale} property='og:locale' />
<meta content={socialImageURL} property='og:image' />
<meta content='1200' property='og:image:width' />
<meta content='630' property='og:image:height' />
<meta content={ogImageAlt ?? `${title} - ${siteConfig.title}`} property='og:image:alt' />
{
  articleDate && (
    <>
      <meta content={siteConfig.author} property='article:author' />
      <meta content={articleDate} property='article:published_time' />
      {articleTags?.map((tag) => <meta content={tag} property='article:tag' />)}
    </>
  )
}

{/* Twitter */}
<meta content='summary_large_image' name='twitter:card' />
<meta content='@funkstyr' name='twitter:site' />
<meta content='@funkstyr' name='twitter:creator' />
<meta content={canonicalURL} name='twitter:url' />
<meta content={title} name='twitter:title' />
<meta content={description} name='twitter:description' />
<meta content={socialImageURL} name='twitter:image' />
<meta content={ogImageAlt ?? `${title} - ${siteConfig.title}`} name='twitter:image:alt' />

{/* Sitemap */}
<link href='/sitemap.xml' rel='sitemap' />

{/* llms.txt discovery */}
<link href='/llms.txt' rel='alternate' title='llms.txt' type='text/plain' />

{/* RSS auto-discovery */}
<link
  href='/rss.xml'
  rel='alternate'
  title={siteConfig.title}
  type='application/rss+xml'
/>

<meta content={Astro.generator} name='generator' />
<JsonLd />
