<script>
  import { applyTheme, resolveTheme } from "../utils/theme";

  // Re-apply theme after Astro view transitions so multi-tab pref changes
  // catch up on navigation.
  document.addEventListener("astro:after-swap", () => applyTheme(resolveTheme()));

  // Follow system preference changes only when the user hasn't picked a theme.
  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
    if (localStorage.getItem("theme")) return;
    applyTheme(e.matches ? "dark" : "light");
  });
</script>
