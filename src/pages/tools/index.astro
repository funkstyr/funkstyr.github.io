---

<PageLayout meta={{ title: "Tools" }}>
  <div class='w-full'>
    <Button title='Back' href='/' style='button'>
      <svg
        xmlns='http://www.w3.org/2000/svg'
        width='14'
        height='14'
        viewBox='0 0 24 24'
        slot='icon-before'
        aria-hidden='true'
      >
        <path
          fill='currentColor'
          d='m6.921 12.5l5.792 5.792L12 19l-7-7l7-7l.713.708L6.921 11.5H19v1z'
        >
        </path>
      </svg>
    </Button>

    <div class='mt-5 flex w-full flex-col gap-y-10'>
      <div>
        <h1 class='mb-1 text-2xl font-bold'>Tools</h1>
        <p>Tools and software I use daily</p>
      </div>

      <ToolSection title='Workspace' tools={WORKSPACE} />
      <ToolSection title='Hosting' tools={HOSTING} />
      <!-- <ToolSection title='Design' tools={DESIGN} /> -->

      <div>
        <h1 class='mb-1 text-2xl font-bold'>Stack</h1>
        <p>Frameworks and libraries I build with</p>
      </div>

      <ToolSection title='Environment' tools={ENVIRONMENT} />
      <ToolSection title='Frameworks' tools={FRAMEWORKS} />
      <ToolSection title='Libraries' tools={LIBRARIES} />
    </div>
  </div>
</PageLayout>
