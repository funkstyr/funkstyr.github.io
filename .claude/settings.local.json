{
  "permissions": {
    "allow": [
      "Bash(bun run *)",
      "Bash(bun install *)",
      "Bash(bun add *)",
      "Bash(bun remove *)",
      "Bash(bun pm *)",
      "Bash(bunx *)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Skill(house-style)",
      "WebSearch",
      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/dist/**)",
      "Read(**/.astro/**)",
      "Read(**/.vercel/**)",
      "Read(**/.netlify/**)",
      "Read(**/coverage/**)",
      "Read(**/bun.lock)",
      "Read(**/bun.lockb)",
      "Read(**/*.tsbuildinfo)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-fix-and-check.sh"
          }
        ]
      }
    ]
  }
}
