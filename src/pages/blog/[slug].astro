---
export const prerender = true;

import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { render } from "astro:content";

import PostLayout from "../../layouts/BlogPost.astro";
import {
  getAllPosts,
  getPostNavigation,
  getRelatedPosts,
  getSeriesContext,
} from "../../utils";

export const getStaticPaths = (async () => {
  const blogEntries = await getAllPosts();
  return Promise.all(
    blogEntries.map(async (entry) => {
      const { prev, next } = getPostNavigation(blogEntries, entry.id);
      const series = await getSeriesContext(blogEntries, entry);
      const related = getRelatedPosts(blogEntries, entry);
      return {
        params: { slug: entry.id },
        props: { entry, prev, next, series, related },
      };
    }),
  );
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { entry, prev, next, series, related } = Astro.props;
const { Content } = await render(entry);
---

<PostLayout post={entry} prev={prev} next={next} series={series} related={related}>
  <Content />
</PostLayout>
